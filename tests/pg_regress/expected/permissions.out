(1 row)

SET typescript.max_allow_env = 'none';
SELECT ts_perm_stmt_fails_with(
  $$SELECT ts_perm_env_path_only('PATH');$$,
  'cannot be fulfilled by'
) AS env_exec_rejects_after_cap_tightened;
